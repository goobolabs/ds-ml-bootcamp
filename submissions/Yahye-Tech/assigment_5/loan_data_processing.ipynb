import pandas as pd
import numpy as np
from sklearn.preprocessing import RobustScaler

# ==========================================
# STEP 1: LOAD & INSPECT
# ==========================================

df = pd.read_csv("raw_loan_dataset.csv")

print("FIRST 5 ROWS")
print(df.head())

print("\nINFO")
print(df.info())

print("\nMISSING VALUES")
print(df.isnull().sum())

print("\nAPPROVED VALUES")
print(df["Approved"].value_counts(dropna=False))

print("\nHAS COLLATERAL VALUES")
print(df["HasCollateral"].value_counts(dropna=False))

print("\nPREVIOUS DEFAULTS VALUES")
print(df["PreviousDefaults"].value_counts(dropna=False))

# ==========================================
# STEP 2: CLEAN CURRENCY
# ==========================================

for col in ["Income", "LoanAmount"]:
    df[col] = (
        df[col]
        .astype(str)
        .str.replace("$", "", regex=False)
        .str.replace(",", "", regex=False)
        .str.strip()
    )

    df[col] = pd.to_numeric(df[col], errors="coerce")

print("\nNUMERIC TYPES")
print(df[["Income", "LoanAmount"]].dtypes)

# ==========================================
# STEP 3: FIX CATEGORY ERRORS
# ==========================================

def clean_binary(value):

    if pd.isna(value):
        return np.nan

    value = str(value).strip().lower()

    yes_values = [
        "yes","y","yse","approved","true","1"
    ]

    no_values = [
        "no","n","rejected","false","0"
    ]

    if value in yes_values:
        return "Yes"

    if value in no_values:
        return "No"

    return np.nan


for col in [
    "HasCollateral",
    "PreviousDefaults",
    "Approved"
]:
    df[col] = df[col].apply(clean_binary)

    print(f"\n{col}")
    print(df[col].value_counts(dropna=False))

# ==========================================
# STEP 4: IMPUTE MISSING
# ==========================================

numeric_cols = [
    "Income",
    "CreditScore",
    "EmploymentYears",
    "LoanAmount"
]

for col in numeric_cols:
    df[col] = df[col].fillna(df[col].median())

categorical_cols = [
    "HasCollateral",
    "PreviousDefaults",
    "Approved"
]

for col in categorical_cols:
    df[col] = df[col].fillna(df[col].mode()[0])

print("\nMISSING AFTER IMPUTATION")
print(df.isnull().sum())

# ==========================================
# STEP 5: REMOVE DUPLICATES
# ==========================================

before = len(df)

df = df.drop_duplicates()

after = len(df)

print("\nROWS BEFORE:", before)
print("ROWS AFTER :", after)
print("REMOVED    :", before-after)

# ==========================================
# STEP 6: OUTLIERS
# ==========================================

outlier_cols = [
    "Income",
    "CreditScore",
    "LoanAmount",
    "EmploymentYears"
]

for col in outlier_cols:

    q1 = df[col].quantile(.25)
    q3 = df[col].quantile(.75)

    iqr = q3-q1

    lower = q1-1.5*iqr
    upper = q3+1.5*iqr

    df[col] = df[col].clip(lower,upper)

print("\nOUTLIERS CAPPED")

# ==========================================
# STEP 7: LABEL ENCODING
# ==========================================

binary = {
    "Yes":1,
    "No":0
}

for col in [
    "Approved",
    "HasCollateral",
    "PreviousDefaults"
]:
    df[col] = df[col].replace(binary)

print("\nCLASS DISTRIBUTION")
print(df["Approved"].value_counts())

# ==========================================
# STEP 8: CLASS BALANCE
# ==========================================

print("\nCLASS COUNTS")
print(df["Approved"].value_counts())

print("\nCLASS PROPORTIONS")
print(df["Approved"].value_counts(normalize=True))

# ==========================================
# STEP 9: FEATURE ENGINEERING
# ==========================================

df["DebtToIncome"] = (
    df["LoanAmount"] /
    (df["Income"]+1)
)

df["IncomePerYearEmployed"] = (
    df["Income"] /
    (df["EmploymentYears"]+1)
)

print("\nNEW FEATURES")
print(df[[
    "DebtToIncome",
    "IncomePerYearEmployed"
]].head())

# ==========================================
# STEP 10: FEATURE SCALING
# ==========================================

scaler = RobustScaler()

scale_cols = [
    "Income",
    "CreditScore",
    "EmploymentYears",
    "LoanAmount",
    "DebtToIncome",
    "IncomePerYearEmployed"
]

df[scale_cols] = scaler.fit_transform(df[scale_cols])

print("\nSCALED DATA")
print(df[scale_cols].head())

# ==========================================
# STEP 11: FINAL CHECKS
# ==========================================

print("\nFINAL INFO")
print(df.info())

print("\nFINAL MISSING VALUES")
print(df.isnull().sum())

print("\nHEAD")
print(df.head())

assert df.isnull().sum().sum() == 0, "There are still missing values."

assert set(df["Approved"].unique()) <= {0,1}

assert set(df["HasCollateral"].unique()) <= {0,1}

assert set(df["PreviousDefaults"].unique()) <= {0,1}

df.to_csv(
    "clean_loan_dataset.csv",
    index=False
)

print("\nDataset saved successfully as clean_loan_dataset.csv")