import pandas as pd
import numpy as np

from sklearn.model_selection import train_test_split

from sklearn.linear_model import LogisticRegression
from sklearn.ensemble import RandomForestClassifier
from sklearn.tree import DecisionTreeClassifier

from sklearn.metrics import (
    accuracy_score,
    precision_score,
    recall_score,
    f1_score,
    confusion_matrix
)

# ==========================================
# STEP 1: LOAD DATASET
# ==========================================

df = pd.read_csv("clean_loan_dataset.csv")

print("First 5 Rows")
print(df.head())

print("\nShape:", df.shape)

# ==========================================
# STEP 2: FEATURES & TARGET
# ==========================================

X = df.drop(columns=["Approved"])
y = df["Approved"]

print("\nFeatures:")
print(X.columns.tolist())

# ==========================================
# STEP 3: TRAIN TEST SPLIT
# ==========================================

X_train, X_test, y_train, y_test = train_test_split(
    X,
    y,
    test_size=0.20,
    stratify=y,
    random_state=42
)

print("\nTraining Samples:", len(X_train))
print("Testing Samples:", len(X_test))

# ==========================================
# STEP 4: TRAIN MODELS
# ==========================================

log_model = LogisticRegression(
    max_iter=1000,
    random_state=42
)

rf_model = RandomForestClassifier(
    n_estimators=100,
    random_state=42
)

dt_model = DecisionTreeClassifier(
    random_state=42
)

log_model.fit(X_train, y_train)
rf_model.fit(X_train, y_train)
dt_model.fit(X_train, y_train)

# ==========================================
# STEP 5: EVALUATION FUNCTION
# ==========================================

def evaluate(model, name):

    pred = model.predict(X_test)

    print("\n==============================")
    print(name)
    print("==============================")

    print("Accuracy :", round(accuracy_score(y_test, pred),3))
    print("Precision:", round(precision_score(y_test, pred),3))
    print("Recall   :", round(recall_score(y_test, pred),3))
    print("F1-Score :", round(f1_score(y_test, pred),3))

    print("\nConfusion Matrix")
    print(confusion_matrix(y_test, pred))

    return pred

log_pred = evaluate(log_model, "Logistic Regression Performance")
rf_pred = evaluate(rf_model, "Random Forest Performance")
dt_pred = evaluate(dt_model, "Decision Tree Performance")

# ==========================================
# STEP 6: SANITY CHECK
# ==========================================

i = 0

sample = X_test.iloc[[i]]

actual = y_test.iloc[i]

print("\n==============================")
print("SANITY CHECK")
print("==============================")

print("Actual:", actual)

print("Logistic Regression:",
      log_model.predict(sample)[0])

print("Random Forest:",
      rf_model.predict(sample)[0])

print("Decision Tree:",
      dt_model.predict(sample)[0])

# ==========================================
# STEP 7: COMPARISON TABLE
# ==========================================

results = pd.DataFrame({
    "Actual": y_test.values,
    "Logistic": log_pred,
    "RandomForest": rf_pred,
    "DecisionTree": dt_pred
})

print("\nPrediction Comparison")
print(results.head())

print("\nNotebook Completed Successfully!")